# =====================================================================
# Golf Weather — Environment Variables
# Copy this file to `.env.local` and fill in your keys.
# The app runs with realistic MOCK DATA when keys are absent, so you
# can develop the full UI without any external accounts.
# =====================================================================

# --- OpenWeather (https://openweathermap.org/api) ---------------------
# Used for current weather, hourly and daily forecasts.
# The "One Call API 3.0" subscription (free tier available) is preferred.
OPENWEATHER_API_KEY=

# --- Geocoding: choose ONE provider (Kakao preferred for Korea) -------
# Kakao Local API: https://developers.kakao.com/  (REST API key)
KAKAO_REST_API_KEY=

# Google Places API (fallback): https://console.cloud.google.com/
GOOGLE_PLACES_API_KEY=

# --- App config -------------------------------------------------------
# Public base URL used for SEO metadata / canonical links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
